# Runtime artifacts
artifacts/certs/*
artifacts/logs/*
artifacts/metrics/*
artifacts/reports/*
results/*

# Keep empty artifact directories
!artifacts/certs/.gitkeep
!artifacts/logs/.gitkeep
!artifacts/metrics/.gitkeep
!artifacts/reports/.gitkeep
!results/.gitkeep

# Cryptographic material
*.key
*.pem
*.crt
*.csr
*.p12
*.pfx

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
venv/

# OS / editor
.DS_Store
.vscode/
.idea/

# Logs
*.log
