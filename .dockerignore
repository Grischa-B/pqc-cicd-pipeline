# Git metadata
.git
.gitignore

# GitHub metadata is not required inside Docker build context
.github

# Runtime artifacts
artifacts/certs/*
artifacts/logs/*
artifacts/metrics/*
artifacts/reports/*

# Keep local placeholders irrelevant for Docker builds
artifacts/**/.gitkeep

# Cryptographic material
*.key
*.pem
*.crt
*.csr
*.p12
*.pfx
*.srl

# Python cache and virtual environments
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
venv/

# Editor / OS files
.vscode/
.idea/
.DS_Store

# Logs
*.log

# Markdown/report files are not needed for image builds
README.md